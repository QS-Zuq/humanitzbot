{
  "name": "humanitz-discord-bot",
  "version": "1.0.0",
  "description": "Discord bot for HumanitZ game server - player stats, server stats, and chat relay",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "setup": "node setup.js",
    "setup:local": "node setup.js --local",
    "setup:find": "node setup.js --find",
    "setup:validate": "node setup.js --validate",
    "deploy-commands": "node src/deploy-commands.js",
    "dev": "node --watch src/index.js",
    "test": "node --test test/*.test.js",
    "build:css": "tailwindcss -i src/web-map/public/tailwind-input.css -o src/web-map/public/tailwind.css --minify",
    "dev:css": "tailwindcss -i src/web-map/public/tailwind-input.css -o src/web-map/public/tailwind.css --watch",
    "build:template": "node src/db/build-template-db.js",
    "changelog": "node tools/generate-changelog.js --output README.md",
    "changelog:json": "node tools/generate-changelog.js --output CHANGELOG.json --format json"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "discord.js": "^14.25.1",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "i18next": "^25.8.18",
    "ssh2-sftp-client": "^12.1.0",
    "ws": "^8.19.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.1",
    "tailwindcss": "^4.2.1"
  }
}
