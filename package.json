{
  "name": "humanitz-discord-bot",
  "version": "1.0.0",
  "description": "Discord bot for HumanitZ game server - player stats, server stats, and chat relay",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "setup": "node setup.js",
    "setup:local": "node setup.js --local",
    "setup:find": "node setup.js --find",
    "setup:validate": "node setup.js --validate",
    "deploy-commands": "node src/deploy-commands.js",
    "dev": "node --watch src/index.js",
    "test": "node --test test/*.test.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{js,json}\" \"test/**/*.js\" \"locales/**/*.json\" \"*.{js,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{js,json}\" \"test/**/*.js\" \"locales/**/*.json\" \"*.{js,json,md}\"",
    "prepare": "husky",
    "build:css": "tailwindcss -i src/web-map/public/tailwind-input.css -o src/web-map/public/tailwind.css --minify",
    "dev:css": "tailwindcss -i src/web-map/public/tailwind-input.css -o src/web-map/public/tailwind.css --watch",
    "build:template": "node src/db/build-template-db.js",
    "changelog": "node tools/generate-changelog.js --output README.md",
    "changelog:json": "node tools/generate-changelog.js --output CHANGELOG.json --format json"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "csurf": "^1.11.0",
    "discord.js": "^14.25.1",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "express-session": "^1.19.0",
    "i18next": "^25.8.18",
    "ssh2-sftp-client": "^12.1.0",
    "ws": "^8.19.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/cli": "^4.2.1",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.1"
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  }
}
