node_modules/
.env
.env.backup*

# Runtime data directory (caches, DB, state files)
# Subdirectories: logs/ (server logs), backups/ (auto-snapshots), game-reference/ (dt-*.txt dumps)
data/*
# Game reference data required for DB seeding
!data/game-tables-raw.json
# Pre-seeded template DB (game reference tables only, no user data)
!data/humanitz-template.db

*.7z
*.sav
*.log

# Dev-only directories
.dev/
.dev

# AI agent work plans (local-only, per-developer)
.sisyphus/
.omc/

# Auto-generated changelog JSON (README.md is the user-facing doc)
CHANGELOG.json

# Personal developer scripts (credentials, diagnostics)
_*.js

# Web map: generated tiles, dev tools, old map images
src/web-map/public/tiles/
src/web-map/public/calibrate.html
src/web-map/public/map-standalone.html
src/web-map/public/island-shape.svg
src/web-map/public/map-*.png
src/web-map/public/map-*.jpg

# Private anticheat engine (separate package — detection logic never in this repo)
qs-anticheat/

# Development / extraction utility scripts & cached data
# tools/ — tracked in howyagarn (private), gitignored in staging/public repos
GameServerSettings.ini
.tmp-*

# Backup files from dev edits
*.bak
# Prevent accidental screenshot/image commits in repo root
/*.png
/*.jpg
/*.jpeg
