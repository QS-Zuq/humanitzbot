# ============================================================
# HumanitZ Discord Bot — Configuration
# ============================================================
# Copy to .env and fill in your values. Defaults shown below.
# Display settings (SHOW_*) are managed via the panel channel
# at runtime — no restart needed. See the settings editor in Discord.
# Schema version: 4 (auto-sync compatible)
ENV_SCHEMA_VERSION=4
FIRST_RUN=true

# ── Discord Bot (required) ───────────────────────────────────
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_CLIENT_ID=your_discord_client_id_here
DISCORD_GUILD_ID=your_discord_guild_id_here

# ── RCON ─────────────────────────────────────────────────────
RCON_HOST=your_server_ip_here
RCON_PORT=8888
RCON_PASSWORD=your_rcon_password_here
GAME_PORT=
PUBLIC_HOST=
SERVER_NAME=

# ── SFTP ─────────────────────────────────────────────────────
# File paths are auto-discovered on first run.
FTP_HOST=
FTP_PORT=2022
FTP_USER=
FTP_PASSWORD=
# Path to SSH private key (optional — replaces password auth)
FTP_PRIVATE_KEY_PATH=

# ── Channel IDs ──────────────────────────────────────────────
# PANEL_CHANNEL_ID is required. Others are optional (module auto-skips if empty).
PANEL_CHANNEL_ID=
ADMIN_CHANNEL_ID=
CHAT_CHANNEL_ID=
LOG_CHANNEL_ID=
SERVER_STATUS_CHANNEL_ID=
PLAYER_STATS_CHANNEL_ID=

BOT_TIMEZONE=UTC
LOG_TIMEZONE=UTC
# Bot display language (en, zh-TW, zh-CN)
BOT_LOCALE=en

#ADMIN_USER_IDS=
#ADMIN_ROLE_IDS=
#ADMIN_ALERT_CHANNEL_IDS=
ADMIN_VIEW_PERMISSIONS=Administrator
DISCORD_INVITE_LINK=

# ── Module Toggles ───────────────────────────────────────────
ENABLE_STATUS_CHANNELS=true
ENABLE_SERVER_STATUS=true
ENABLE_CHAT_RELAY=true
ENABLE_AUTO_MESSAGES=true
ENABLE_PLAYTIME=true
ENABLE_LOG_WATCHER=true
ENABLE_PLAYER_STATS=true
ENABLE_MILESTONES=false
ENABLE_RECAPS=false
#ENABLE_ANTICHEAT=false
#ANTICHEAT_ANALYZE_INTERVAL=60000
#ANTICHEAT_BASELINE_INTERVAL=900000
USE_CHAT_THREADS=true
USE_ACTIVITY_THREADS=true

# ── Log Watcher ──────────────────────────────────────────────
ENABLE_KILL_FEED=true
ENABLE_PVP_KILL_FEED=true
#PVP_KILL_WINDOW=60000
ENABLE_DEATH_LOOP_DETECTION=true
#DEATH_LOOP_THRESHOLD=3
#DEATH_LOOP_WINDOW=60000

# ── Auto Messages ────────────────────────────────────────────
ENABLE_AUTO_MSG_LINK=true
ENABLE_AUTO_MSG_PROMO=true
ENABLE_WELCOME_MSG=true
ENABLE_WELCOME_FILE=true
#AUTO_MSG_LINK_TEXT=
#AUTO_MSG_PROMO_TEXT=
#WELCOME_FILE_LINES=

# ── PvP Scheduler ────────────────────────────────────────────
ENABLE_PVP_SCHEDULER=false
PVP_START_TIME=18:00
PVP_END_TIME=22:00
#PVP_RESTART_DELAY=10
#PVP_UPDATE_SERVER_NAME=false
#PVP_DAYS=
#PVP_SETTINGS_OVERRIDES=
#PVP_HOURS_MON= through PVP_HOURS_SUN= (HH:MM-HH:MM per-day overrides)

# ── Server Scheduler ─────────────────────────────────────────
ENABLE_SERVER_SCHEDULER=false
#RESTART_TIMES=06:00,18:00
#RESTART_DELAY=10
#RESTART_PROFILES=
#RESTART_ROTATE_DAILY=true
#DOCKER_CONTAINER=hzserver

# ── Activity Log ─────────────────────────────────────────────
ENABLE_ACTIVITY_LOG=true
ACTIVITY_LOG_CHANNEL_ID=
ENABLE_CONTAINER_LOG=true
ENABLE_HORSE_LOG=true
ENABLE_VEHICLE_LOG=true
SHOW_INVENTORY_LOG=false
SHOW_INVENTORY_LOG_ADMIN_ONLY=true

# ── Poll Intervals (ms, defaults shown) ──────────────────────
#SAVE_POLL_INTERVAL=300000
#LOG_POLL_INTERVAL=30000
#CHAT_POLL_INTERVAL=10000
#SERVER_STATUS_INTERVAL=30000
#BOT_PROFILE_STATUS_INTERVAL=30000

# ── Pterodactyl Panel API (optional) ─────────────────────────
#PANEL_SERVER_URL=
#PANEL_API_KEY=
ENABLE_PANEL=true
ENABLE_GAME_SETTINGS_EDITOR=true
#ENABLE_SSH_RESOURCES=false
#SSH_PORT=
#RESOURCE_CACHE_TTL=30000

# ── Agent Mode (optional — reduces bandwidth) ────────────────
# auto = try agent, fall back to full .sav | agent = agent only | direct = full .sav
AGENT_MODE=auto
# auto = RCON → SSH → none | rcon | panel | ssh | none
AGENT_TRIGGER=auto
# RCON/console command that tells the server to write humanitz-cache.json
#AGENT_PANEL_COMMAND=createHZSocket
# ms to wait after trigger before downloading cache (default: 3000)
#AGENT_PANEL_DELAY=3000
#AGENT_NODE_PATH=node
#AGENT_REMOTE_DIR=
#AGENT_CACHE_PATH=
#AGENT_TIMEOUT=120000
#AGENT_POLL_INTERVAL=90000

# ── SFTP File Paths (auto-discovered on first run) ───────────
# These are auto-discovered by `npm run setup`. Leave blank for auto-detection.
# Only set manually if auto-discovery fails.
# FTP_SAVE_PATH supports custom save names — if you changed SaveName in
# GameServerSettings.ini, set this to the full path of your Save_YourName.sav
#FTP_BASE_PATH=
#FTP_LOG_PATH=
#FTP_CONNECT_LOG_PATH=
#FTP_ID_MAP_PATH=
#FTP_SAVE_PATH=
#FTP_SETTINGS_PATH=
#FTP_WELCOME_PATH=

ENABLE_STDIN_CONSOLE=false
STDIN_CONSOLE_WRITABLE=false

# ── Web Panel (optional) ──────────────────────────────────────
WEB_MAP_PORT=
DISCORD_OAUTH_SECRET=
WEB_MAP_CALLBACK_URL=
# Trust proxy for Express (default: loopback). Set to 1 for Pterodactyl/Docker hosts.
#WEB_MAP_TRUST_PROXY=loopback
#WEB_MAP_SESSION_SECRET=       # Auto-generated if not set (sessions won't survive restarts)
#WEB_PANEL_SURVIVOR_ROLES=     # Discord role IDs for survivor access (comma-separated). Empty = any guild member
#WEB_PANEL_MOD_ROLES=          # Discord role IDs for mod access
#WEB_PANEL_ADMIN_ROLES=        # Discord role IDs for admin access. Empty = Discord Administrator permission
NUKE_BOT=false
