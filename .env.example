# ============================================================
# HumanitZ Discord Bot — Bootstrap Configuration
# ============================================================
# Only these keys are needed in .env. All other settings are
# managed through the Discord Panel Channel or Web Dashboard
# and stored in the SQLite database.
#
# After first run, edit settings via the Panel or Dashboard.
# Schema version: 5 (auto-sync compatible)
ENV_SCHEMA_VERSION=5
FIRST_RUN=true

# ── Discord Bot (required) ───────────────────────────────────
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_CLIENT_ID=your_discord_client_id_here
DISCORD_GUILD_ID=your_discord_guild_id_here
PANEL_CHANNEL_ID=

# ── Web Dashboard (optional) ────────────────────────────────
#WEB_MAP_PORT=3000
#DISCORD_OAUTH_SECRET=
#WEB_MAP_CALLBACK_URL=
#WEB_MAP_SESSION_SECRET=
#WEB_MAP_TRUST_PROXY=loopback

NUKE_BOT=false
