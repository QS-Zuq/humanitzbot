# ============================================================
# HumanitZ Discord Bot — Bootstrap Configuration
# ============================================================
# Fill in the Discord credentials below, then run `npm run setup`
# to configure RCON, SFTP, and other settings via CLI.
# All settings are stored in the SQLite database.
#
# After first run, edit settings in .env or via the Web Dashboard.
# Schema version: 9 (auto-sync compatible)
ENV_SCHEMA_VERSION=9
FIRST_RUN=true

# ── Discord Bot (required) ───────────────────────────────────
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_CLIENT_ID=your_discord_client_id_here
DISCORD_GUILD_ID=your_discord_guild_id_here

# ── RCON (optional — configure in .env or via Web Dashboard) ────────────
#RCON_HOST=your.game.server.ip
#RCON_PORT=27015
#RCON_PASSWORD=your_rcon_password

# ── SFTP (optional — configure in .env or via Web Dashboard) ──────────
#SFTP_HOST=your.game.server.ip
#SFTP_PORT=2022
#SFTP_USER=your_sftp_username
#SFTP_PASSWORD=your_sftp_password

# ── Web Dashboard (optional — required for web panel auth) ──
# Without DISCORD_OAUTH_SECRET + WEB_MAP_CALLBACK_URL, the web panel
# login is disabled (landing page only, no panel access).
# Get your OAuth secret from Discord Developer Portal → OAuth2.
WEB_MAP_PORT=3000
DISCORD_OAUTH_SECRET=
WEB_MAP_CALLBACK_URL=
#WEB_MAP_SESSION_SECRET=
#WEB_MAP_TRUST_PROXY=loopback

# Test auth token for E2E tests and local AI automation. Coexists with OAuth
# (real users still log in via Discord). Token must be at least 32 characters.
# Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Production safety: startup refuses to register /auth/test-login if
# NODE_ENV=production. Leave empty in production.
#WEB_PANEL_TEST_AUTH_TOKEN=


NUKE_BOT=false
